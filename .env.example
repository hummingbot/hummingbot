# WEEX Production Deployment Environment Variables
# Copy this file to .env and fill in your actual credentials

# ============================================================================
# Market Making Bot Configuration
# ============================================================================
# API Keys for Trading (Sub-Account 1: VCC Market Making)
WEEX_MM_API_KEY=your_mm_trading_api_key_here
WEEX_MM_API_SECRET=your_mm_trading_api_secret_here
WEEX_MM_PASSPHRASE=your_mm_trading_passphrase_here

# Monitoring API Keys (Read-Only)
WEEX_MM_MONITOR_API_KEY=your_mm_monitor_api_key_here
WEEX_MM_MONITOR_API_SECRET=your_mm_monitor_api_secret_here
WEEX_MM_MONITOR_PASSPHRASE=your_mm_monitor_passphrase_here

# Bot Configuration Password
MM_CONFIG_PASSWORD=admin

# ============================================================================
# Volume Generation Bot Configuration
# ============================================================================
# API Keys for Trading (Sub-Account 2: VCC Volume Generation)
WEEX_VOL_API_KEY=your_vol_trading_api_key_here
WEEX_VOL_API_SECRET=your_vol_trading_api_secret_here
WEEX_VOL_PASSPHRASE=your_vol_trading_passphrase_here

# Monitoring API Keys (Read-Only)
WEEX_VOL_MONITOR_API_KEY=your_vol_monitor_api_key_here
WEEX_VOL_MONITOR_API_SECRET=your_vol_monitor_api_secret_here
WEEX_VOL_MONITOR_PASSPHRASE=your_vol_monitor_passphrase_here

# Bot Configuration Password
VOL_CONFIG_PASSWORD=admin

# ============================================================================
# Deployment Configuration
# ============================================================================
# Docker image tag
IMAGE_TAG=latest

# Timezone
TZ=UTC

# ============================================================================
# Security Notes
# ============================================================================
# 1. Never commit this file with real credentials to git
# 2. Keep .env in .gitignore
# 3. Use different passwords for each environment
# 4. Rotate API keys regularly
# 5. Use IP whitelisting on WEEX for all API keys
